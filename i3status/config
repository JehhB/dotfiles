general {
  output_format = "i3bar"
  colors = true
  interval = 5
}

order += "battery all"
order += "time"
order += "tztime local"

battery all {
  status_chr = "🔌"
  status_bat = "⚡"
  status_unk = "🚫"
  status_full = "🔋"
  low_threshold = 5
}

time {
  format = "%H:%M"
}

tztime local {
  format = "(%a) %m/%d"
}
